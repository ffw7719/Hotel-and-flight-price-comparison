# 数据库配置
MONGODB_URI=mongodb://localhost:27017/price-comparison
REDIS_URL=redis://localhost:6379

# 服务器配置
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# 爬虫配置
PUPPETEER_HEADLESS=true
SCRAPER_TIMEOUT=30000
SCRAPER_RETRY_COUNT=3
SCRAPER_DELAY_BETWEEN_REQUESTS=1000

# 平台配置
MEITUAN_BASE_URL=https://hotel.meituan.com
CTRIP_BASE_URL=https://www.ctrip.com
FLIGGY_BASE_URL=https://www.fliggy.com

# 缓存配置
CACHE_TTL=3600
CACHE_PREFIX=price-comparison

# 日志配置
LOG_LEVEL=info
LOG_FILE_PATH=logs/

# 限流配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 监控配置
ENABLE_METRICS=true
METRICS_PORT=9090